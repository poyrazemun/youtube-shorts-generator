# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
client_secrets.json
credentials.json
token.json
token*.json
*_secret*.json
*.pem
*.key
*.p12
*.pfx

# ── Pipeline output ───────────────────────────────────────────────────────────
output/
test_output/
logs/
*.log

# ── Assets (user-supplied, not tracked) ───────────────────────────────────────
assets/music/
assets/images/
assets/audio/
assets/video/
# Personal voice recordings (biometric data — never commit)
assets/voice_sample.wav
assets/voice_sample.m4a
voice-Merve.m4a
*.m4a
*.wav
!assets/music/*.mp3

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Whisper model cache ───────────────────────────────────────────────────────
# Whisper downloads models to ~/.cache/whisper — nothing to ignore here,
# but if you ever cache locally:
*.pt

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Dev reference docs (kept in Claude memory, not in repo) ───────────────────
PROJECT_CONTEXT.md
NEXT_STEPS.md
ROADMAP.md

# ── Local-only data files ──────────────────────────────────────────────────────
video_registry.json
topics_queue.json

# ── Cost tracking (per-run cost.json + chronological ledger) ──────────────────
# These live under output/ which is already ignored above, but listed
# explicitly so they stay out of the repo even if output/ is ever un-ignored.
output/cost_ledger.txt
output/**/cost.json

# ── Marketing & growth strategy (local only) ──────────────────────────────────
growth/
marketing/

# ── Local planning ────────────────────────────────────────────────────────────
TO-DO/
prompts/
improvements.md
readme_improvements.md
on_uploading_moment.md
notes_for_next_session.txt

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
.claude/*
