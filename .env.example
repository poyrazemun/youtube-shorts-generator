# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# ── API Keys ──────────────────────────────────────────────────────────────────
# Anthropic API key for Claude (script generation). Required.
ANTHROPIC_API_KEY=sk-ant-...

# Replicate API token for FLUX image generation. Required if using Replicate backend.
REPLICATE_API_TOKEN=r8_...

# Hugging Face token for HF Inference API image backend. Optional alternative to Replicate.
HUGGINGFACE_API_TOKEN=hf_...

# ── YouTube OAuth ─────────────────────────────────────────────────────────────
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console.
YOUTUBE_CLIENT_SECRETS_FILE=./client_secrets.json

# Upload visibility: "private", "unlisted", or "public". Default "private" for safety.
YOUTUBE_PRIVACY=private

# ── Logging ───────────────────────────────────────────────────────────────────
# Python logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# ── ElevenLabs TTS (highest quality, hosted — top of priority chain) ──────────
# Env-gated: only used when ELEVENLABS_ENABLED is truthy AND a key is set.
# Falls back to Kokoro otherwise. Starter plan ($5/mo) required for commercial use.
ELEVENLABS_API_KEY=
ELEVENLABS_ENABLED=false
# Voice id from the ElevenLabs voice library. Default "George" (British narrator).
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# eleven_multilingual_v2 (quality) | eleven_turbo_v2_5 / eleven_flash_v2_5 (½ credits)
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Piper TTS (legacy / fallback) ─────────────────────────────────────────────
# Piper voice model name (must be installed locally).
PIPER_MODEL=en_US-lessac-medium
# Piper binary name or absolute path; must be on PATH if name-only.
PIPER_BINARY=piper

# ── Kokoro TTS (default) ──────────────────────────────────────────────────────
# Voice id: af_heart, am_echo, bf_emma, bm_george, ...
KOKORO_VOICE=bm_george
# Language code: 'a' = American English, 'b' = British English.
KOKORO_LANG_CODE=b
# Playback speed multiplier (1.0 = normal).
KOKORO_SPEED=1.1

# ── Subtitles ─────────────────────────────────────────────────────────────────
# Global subtitle timing nudge in seconds (negative = earlier, positive = later).
SUBTITLE_TIME_OFFSET=0.0

# ── Historical Fact-Check ─────────────────────────────────────────────────────
# After each script is generated, a swift Haiku pass scans the 5 beats for
# pop-history myths / fabricated drama and corrects them before saving. On by
# default; set to false to skip the extra call (e.g. while debugging).
FACTCHECK_ENABLED=true

# ── Scene Planning ────────────────────────────────────────────────────────────
# Default preset key from pipeline.presets.PRESETS (e.g. "documentary_clean").
DEFAULT_SCENE_PRESET=documentary_clean
